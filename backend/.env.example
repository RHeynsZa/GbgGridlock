# Database connection string (provided by Railway's TimescaleDB service)
DATABASE_URL=postgresql://gbg:gbg@localhost:5432/gbggridlock

# Västtrafik API credentials (required for polling worker)
# Get these from https://developer.vasttrafik.se/
VT_CLIENT_ID=your_client_id_here
VT_CLIENT_SECRET=your_client_secret_here

# Worker configuration (optional - set to "true" to enable background polling)
ENABLE_WORKER=false

# Worker settings (optional - only needed if ENABLE_WORKER=true)
WORKER_INTERVAL_SECONDS=60
WORKER_HTTP_CONCURRENCY=5
