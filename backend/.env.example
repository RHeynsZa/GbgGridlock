# Database Configuration
# For Railway: Use the DATABASE_URL from Railway's TimescaleDB service
DATABASE_URL=postgresql://user:password@host:port/database

# Västtrafik API Credentials
# Get these from https://developer.vasttrafik.se/
VT_CLIENT_ID=your_client_id_here
VT_CLIENT_SECRET=your_client_secret_here

# Optional: Västtrafik API Configuration
VT_TOKEN_URL=https://ext-api.vasttrafik.se/token
VT_API_BASE_URL=https://ext-api.vasttrafik.se/pr/v4

# Worker Configuration
POLL_INTERVAL_SECONDS=60
HTTP_CONCURRENCY=5
ENABLE_WORKER=true
